<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="RideFlow — Intelligent ride-hailing platform management system">
  <title>RideFlow</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/public/css/style.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>

<nav class="rf-nav">
  <a class="rf-nav-brand" href="/">Ride<span>Flow</span></a>
  <div class="rf-nav-right">
    <% if (user) { %>
      <span class="rf-nav-user"><%= user.name %></span>
      <span class="rf-nav-role"><%= user.role %></span>
      <form method="POST" action="/logout" class="m-0">
        <button class="btn btn-outline-light btn-sm">Logout</button>
      </form>
    <% } %>
  </div>
</nav>

<main class="container-fluid py-4">
<% if (flash) { %>
  <div class="alert alert-<%= flash.type %> alert-dismissible fade show" role="alert">
    <%= flash.message %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>
